# Shared secret used for internal service-to-service authentication.
# In production, replace with mTLS certificates (mutual TLS is preferred
# for service-to-service auth as it provides mutual authentication at the
# TLS layer without token management overhead).
SERVICE_API_KEY=super-secret-internal-key-change-in-prod

# JWT secret for signing payment links (HS256 algorithm)
# Generate with: openssl rand -base64 32
# This secret is shared between order-service and payment-service
JWT_SECRET=your-random-32-byte-base64-encoded-secret-here-change-in-production
